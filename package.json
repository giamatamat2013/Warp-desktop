{
  "name": "warp-desktop",
  "version": "1.0.0",
  "description": "WARP Desktop – משחקי חינם בלי דפדפן",
  "main": "main.js",
  "author": "WARP",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64"
  },
  "build": {
    "appId": "com.warp.desktop",
    "productName": "WARP Desktop",
    "copyright": "© 2025 WARP",
    "directories": { "output": "dist" },
    "files": [
      "main.js",
      "preload.js",
      "preload-game.js",
      "src/**/*",
      "assets/**/*"
    ],
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        { "target": "nsis",     "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "WARP Desktop",
      "artifactName": "WARP-Setup-${version}.exe"
    },
    "portable": {
      "artifactName": "WARP-Portable-${version}.exe"
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^25.0.0"
  }
}